{
  "name": "decky-toy-haptics",
  "version": "0.0.1",
  "description": "Route Steam Deck game haptics to Buttplug-compatible toys via a bundled intiface-engine.",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:ui:serve": "vite --config tests/frontend/harness/vite.config.ts tests/frontend/harness",
    "test:ui": "playwright test --config tests/frontend/playwright.config.ts",
    "lint": "eslint src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SteamDeckHomebrew/decky-plugin-template.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "plugin-template",
    "steam-deck",
    "deck"
  ],
  "author": "Madrigal Eschat",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/SteamDeckHomebrew/decky-plugin-template/issues"
  },
  "homepage": "https://github.com/SteamDeckHomebrew/decky-plugin-template#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup": "^4.53.3",
    "semantic-release": "^25.0.5",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
